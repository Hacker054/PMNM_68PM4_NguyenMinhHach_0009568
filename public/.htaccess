Options -Indexes

#Đảm bảo rằng yêu cầu không phải là một
RewriteCond %(REQUEST_FILENAME) !-f
RewriteCond %(REQUEST_FILENAME) !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

#Điều hướng tất cả các yêu cầu tới index
RewriteRule ^ index.php [L,QSA]
RewriteRule ^(.*)$ index.php?url=$1